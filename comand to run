$project = "D:\buddie_app_run"
$flutter = "C:\src\flutter\bin\flutter.bat"
$adb = "C:\Android\Sdk\platform-tools\adb.exe"

$env:JAVA_HOME = "C:\Program Files\Android\Android Studio\jbr"
$env:PUB_CACHE = "D:\pub-cache"
$env:Path = "C:\src\flutter\bin;C:\Program Files\Android\Android Studio\jbr\bin;C:\Android\Sdk\platform-tools;$env:Path"

Set-Location $project

& $flutter clean
& $flutter pub get
& $flutter build apk --debug

& $adb kill-server
& $adb start-server
& $adb devices

& $adb install -r "$project\build\app\outputs\flutter-apk\app-debug.apk"
& $adb shell monkey -p inc.buddie.memx -c android.intent.category.LAUNCHER 1


///////////////////////////////////////////////////////

$adb = "C:\Android\Sdk\platform-tools\adb.exe"

# terminal 1
& $adb logcat -G 32M
& $adb logcat -c
& $adb logcat -v time -s flutter:I


/////////////////////////////////

& $adb logcat -d | findstr /I "TTS_TRACE UI_TTS_TRACE record start asrMode start chat stream"
